{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "file_id": {
      "type": "string",
      "description": "Identifiant du fichier template .odt préalablement uploadé via POST /v1/storage/upload",
      "examples": ["client1/a1b2c3d4/info_procureur.odt"]
    },
    "data": {
      "type": "object",
      "description": "Dictionnaire des placeholders à remplir dans le template. Les valeurs peuvent être des chaînes, des booléens, ou des listes (pour les boucles Relatorio).",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "boolean" },
          { "type": "array", "items": {} }
        ]
      },
      "examples": [
        {
          "nom_prefecture": "Nice",
          "date_arrete": "23.03.2026",
          "is_admin": "oui",
          "items": ["dossier-001", "dossier-002"]
        }
      ]
    }
  },
  "required": ["file_id", "data"],
  "additionalProperties": false
}
